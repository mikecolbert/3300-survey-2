# Supabase credentials — required for the app to connect to the database.
#
# For local development: copy this file to .env and fill in your values.
#   cp .env.example .env
#
# For Azure Static Web Apps: set these in the Azure portal under
#   your Static Web App → Settings → Environment variables.
#   Do NOT commit real values to source control.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
